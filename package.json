{
  "name": "eye-friendly-font-replacer",
  "version": "1.0.27",
  "type": "commonjs",
  "description": "Chrome extension to replace hard-to-read fonts with user-selected Japanese fonts",
  "scripts": {
    "generate-icons": "node scripts/generate-icons.js",
    "generate-css": "node scripts/generate-css.js",
    "convert-fonts": "node scripts/convert-fonts.js",
    "generate-screenshots": "node scripts/generate-screenshots.js",
    "build": "npm run generate-icons && npm run generate-css"
  },
  "devDependencies": {
    "chrome-webstore-upload-cli": "3.5.0",
    "puppeteer": "^24.0.0",
    "sharp": "^0.34.5",
    "ttf2woff2": "^8.0.0"
  },
  "keywords": [
    "chrome-extension",
    "font",
    "noto-sans",
    "japanese"
  ],
  "author": "ゆろち",
  "license": "MIT"
}
