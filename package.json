{
  "name": "eye-friendly-font-replacer",
  "version": "3.0.3",
  "type": "commonjs",
  "description": "Chrome/Firefox extension that replaces hard-to-read fonts with Japanese fonts. Variant-based build mechanism is retained for future brand spin-offs; only the 'default' variant is shipped.",
  "scripts": {
    "generate-icons": "node scripts/generate-icons.js",
    "generate-icons:default": "node scripts/generate-icons.js default",
    "generate-css": "node scripts/generate-css.js",
    "convert-fonts": "node scripts/convert-fonts.js",
    "generate-screenshots": "node scripts/generate-screenshots.js",
    "generate-screenshots:default": "node scripts/generate-screenshots.js default",
    "build-variant": "node scripts/build-variant.js",
    "build:default": "node scripts/generate-icons.js default && npm run generate-css && node scripts/build-variant.js default",
    "build": "npm run build:default",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "chrome-webstore-upload-cli": "3.5.0",
    "puppeteer": "^24.0.0",
    "sharp": "^0.34.5",
    "ttf2woff2": "^8.0.0",
    "web-ext": "10.1.0"
  },
  "keywords": [
    "chrome-extension",
    "font",
    "noto-sans",
    "japanese"
  ],
  "author": "ゆろち",
  "license": "MIT"
}
