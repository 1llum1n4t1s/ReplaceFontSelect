{
  "name": "eye-friendly-font-replacer",
  "version": "1.0.27",
  "type": "commonjs",
  "description": "Chrome extension to replace hard-to-read fonts with user-selected Japanese fonts",
  "scripts": {
    "generate-icons": "node scripts/generate-icons.js",
    "generate-icons:default": "node scripts/generate-icons.js default",
    "generate-icons:notosans": "node scripts/generate-icons.js notosans",
    "generate-css": "node scripts/generate-css.js",
    "convert-fonts": "node scripts/convert-fonts.js",
    "generate-screenshots": "node scripts/generate-screenshots.js",
    "generate-screenshots:default": "node scripts/generate-screenshots.js default",
    "generate-screenshots:notosans": "node scripts/generate-screenshots.js notosans",
    "build-variant": "node scripts/build-variant.js",
    "build:default": "node scripts/generate-icons.js default && npm run generate-css && node scripts/build-variant.js default",
    "build:notosans": "node scripts/generate-icons.js notosans && npm run generate-css && node scripts/build-variant.js notosans",
    "build": "npm run build:default",
    "release": "node scripts/release.js",
    "release:default": "node scripts/release.js default",
    "release:notosans": "node scripts/release.js notosans",
    "release:all": "node scripts/release.js all"
  },
  "devDependencies": {
    "chrome-webstore-upload-cli": "3.5.0",
    "puppeteer": "^24.0.0",
    "sharp": "^0.34.5",
    "ttf2woff2": "^8.0.0"
  },
  "keywords": [
    "chrome-extension",
    "font",
    "noto-sans",
    "japanese"
  ],
  "author": "ゆろち",
  "license": "MIT"
}
