{
  "manifest_version": 3,
  "name": "目に優しいフォント置換",
  "version": "1.0.26",
  "description": "読みづらいフォントを好みの日本語フォントに自動置換。フォント選択機能付き。",
  "browser_specific_settings": {
    "gecko": {
      "id": "{ee49eeb2-93a9-4062-ba75-06610054323f}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/inject.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/font-config.js",
        "src/content/preload-fonts.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/fonts/*.woff2",
        "src/css/*.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}