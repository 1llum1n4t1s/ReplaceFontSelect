# Dependencies
node_modules/

# Build outputs
*.log
*.tmp
*.zip
*.xpi
webstore/images/
temp-build/

# Variant build outputs (生成: scripts/build-variant.js)
# manifest.json は manifest.template.json + variants/<name>.json から生成される。
# src/content/variant.js も同様。Git 管理せず、ビルド時に必ず生成する。
manifest.json
src/content/variant.js

# Generated icons (from scripts/generate-icons.js)
# 旧パス: icons/icon-*.png は variant 化前の生成物。
# 新パス: icons/<variant>/icon-*.png （variant ごとに SVG から再生成される）
icons/icon-*.png
icons/*/icon-*.png

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
debug/
*.swp
*.swo

# Chrome extension reserved
_metadata/
temp/

# Claude Code local settings (personal, may contain machine-specific permissions)
.claude/settings.local.json

# Serena MCP working files
.serena/

# web-ext sign 用の一時ビルドディレクトリ
firefox-build/

# cxcx (Chrome 拡張パフォーマンス計測スキル) の出力
# trace.json / cpuprofile に計測対象サイトの URL リストが含まれるため git track 厳禁。
# improvement-report.md だけ残したい時は `!cxcx-out/improvement-report.md` で例外指定。
cxcx-out/

# cxcx のシナリオ YAML (ローカル計測用、 配布対象外)
cxcx-scenarios.yaml

# CSS テンプレート (generate-css.js が生成、 preset JS の元データだが配布物には不要)
src/css/replacefont-extension.css

# 生成された preset JS 36 個 (generate-css.js が生成、 ビルド時に毎回再生成)
src/css/preset-*.js

# AMO ローカル submission 用メタデータ (web-ext sign --amo-metadata 引数で渡す、
# 配布対象外。 退役 variant のメタも残る場合あり)
.amo-metadata*.json
