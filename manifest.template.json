{
  "manifest_version": 3,
  "name": "__VARIANT_NAME__",
  "version": "__VARIANT_VERSION__",
  "description": "__VARIANT_DESCRIPTION__",
  "browser_specific_settings": {
    "gecko": {
      "id": "__VARIANT_GECKO_ID__",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "scripting",
    "alarms"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; form-action 'none'"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/inject.js"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/variant.js",
        "src/content/font-config.js",
        "src/content/preload-fonts.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/fonts/*.woff2",
        "src/css/replacefont-extension.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
